# Clé API Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Clé API Fal.ai (génération d'images, héberge Qwen-Image) — https://fal.ai/dashboard/keys
FAL_KEY=

# Modèle d'écriture (Claude). Défaut : claude-opus-4-8 (qualité max).
# Astuce coût à l'échelle : claude-sonnet-4-6 (~2x moins cher).
STORY_MODEL=claude-opus-4-8

# Modèle d'images sur Fal.ai. Défaut : Qwen Image 2 (texte→image).
IMAGE_MODEL=fal-ai/qwen-image-2/text-to-image

# Voix des histoires : ElevenLabs en DIRECT (ton abonnement) — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Modèle de voix ElevenLabs. Défaut : eleven_multilingual_v2 (français). Alt : eleven_turbo_v2_5 (rapide).
ELEVENLABS_MODEL=eleven_multilingual_v2
