# Clé API Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Clé API Fal.ai (génération d'images, héberge Qwen-Image) — https://fal.ai/dashboard/keys
FAL_KEY=

# Modèle d'écriture (Claude). Défaut : claude-opus-4-8 (qualité max).
# Astuce coût à l'échelle : claude-sonnet-4-6 (~2x moins cher).
STORY_MODEL=claude-opus-4-8

# Modèle d'images sur Fal.ai. Défaut : Qwen Image 2 (texte→image).
IMAGE_MODEL=fal-ai/qwen-image-2/text-to-image

# Voix des histoires : ElevenLabs en DIRECT (ton abonnement) — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Modèle de voix ElevenLabs. Défaut : eleven_multilingual_v2 (français). Alt : eleven_turbo_v2_5 (rapide).
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Quota anti-abus côté serveur (api/_quota.js) ────────────────────────────────
# Redis via Upstash (« Vercel KV »). Crée un store Redis dans l'onglet Storage de Vercel :
# les deux variables ci-dessous sont fournies automatiquement au projet. SANS elles, le
# quota est simplement désactivé (aucun blocage). AVEC elles, l'usage de génération est
# plafonné par IP / par appareil / globalement — infalsifiable, contre les boucles curl.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Limites (unités ; 1 histoire ≈ 27 unités). Réglables à chaud dans Vercel, sans redéploiement.
# Laisse vide pour garder les défauts : 150/IP/heure, 400/appareil/jour, pas de plafond global.
RL_IP_PER_HOUR=150
RL_DEVICE_PER_DAY=400
RL_GLOBAL_PER_DAY=0
