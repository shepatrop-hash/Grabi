# Clé API Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Clé API Fal.ai (images ET voix/audio — héberge Qwen-Image & ElevenLabs) — https://fal.ai/dashboard/keys
FAL_KEY=

# Modèle d'écriture (Claude). Défaut : claude-opus-4-8 (qualité max).
# Astuce coût à l'échelle : claude-sonnet-4-6 (~2x moins cher).
STORY_MODEL=claude-opus-4-8

# Modèle d'images sur Fal.ai. Défaut : Qwen Image 2 (texte→image).
IMAGE_MODEL=fal-ai/qwen-image-2/text-to-image

# Modèle de voix (TTS) sur Fal.ai. Défaut : ElevenLabs Multilingual v2.
# Alternatives : fal-ai/elevenlabs/tts/turbo-v2.5 (moins cher), .../eleven-v3 (plus expressif).
TTS_MODEL=fal-ai/elevenlabs/tts/multilingual-v2
